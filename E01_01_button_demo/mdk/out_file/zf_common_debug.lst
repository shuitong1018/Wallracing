  241          {
  242   1              if(len > 0xFFFF)
  243   1              {
  244   2                      uart_write_buffer(DEBUG_UART_INDEX, buff, 0xFFFF);
  245   2                      return  len - 0xFFFF;
  246   2              }
  247   1              else

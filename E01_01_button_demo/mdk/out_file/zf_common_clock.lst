   54          uint32 set_sys_clk(uint32 sys_clk)
   55          {
   56   1              
   57   1              P_SW2 |= 0x80;
   58   1                      
   59   1              switch(sys_clk) 
   60   1              {
   61   2                      case SYSTEM_CLOCK_22_1184M:
   62   2                              // йҖүжӢ© 22.1184MHz
   63   2                              CLKDIV = 0x04;
   64   2                              IRTRIM = T22M_ADDR;
   65   2                              VRTRIM = VRT27M_ADDR;
   66   2                              IRCBAND = 0x02;
   67   2                              CLKDIV = 0x00;
   68   2                      break;
   69   2                              
   70   2                      case SYSTEM_CLOCK_24M:
   71   2                              // йҖүжӢ© 24MHz
   72   2                              CLKDIV = 0x04;
   73   2                              IRTRIM = T24M_ADDR;
   74   2                              VRTRIM = VRT27M_ADDR;
   75   2                              IRCBAND = 0x02;
   76   2                              CLKDIV = 0x00;
   77   2                      break;
   78   2                              
   79   2                      case SYSTEM_CLOCK_27M:
   80   2                              // йҖүжӢ© 27MHz
   81   2                              CLKDIV = 0x04;
   82   2                              IRTRIM = T27M_ADDR;
   83   2                              VRTRIM = VRT27M_ADDR;
   84   2                              IRCBAND = 0x02;
   85   2                              CLKDIV = 0x00;
   86   2                      break;
   87   2                              
   88   2                      case SYSTEM_CLOCK_30M:
   89   2                              // йҖүжӢ© 30MHz
   90   2                              CLKDIV = 0x04;
   91   2                              IRTRIM = T30M_ADDR;
   92   2                              VRTRIM = VRT27M_ADDR;
   93   2                              IRCBAND = 0x02;
   94   2                              CLKDIV = 0x00;
   95   2                      break;
   96   2                              
   97   2                      case SYSTEM_CLOCK_33_1776M:
   98   2                              // йҖүжӢ© 33.1776MHz
   99   2                              CLKDIV = 0x04;
  100   2                              IRTRIM = T33M_ADDR;
  101   2                              VRTRIM = VRT27M_ADDR;
  102   2                              IRCBAND = 0x02;
  103   2                              CLKDIV = 0x00;
  104   2                      break;
  105   2                              

  134                  //  @since      v1.0
  135                  //  Sample usage:
  136                  //------------------------------------------------------------------------------------------------------
             --------------
  137                  static uint8 imu963ra_simspi_wr_byte(uint8 byte)
  138                  {
  139   1                      uint8 i;
  140   1                      for(i=0; i<8; i++)
  141   1                      {
  142   2                              IMU963RA_SCK (0);
  143   2                              IMU963RA_MOSI(byte&0x80);
  144   2                              byte <<= 1;
  145   2                              IMU963RA_SCK (1);
  146   2                              byte |= IMU963RA_MISO;
  147   2                      }
  148   1                      IMU963RA_SCK (0);
  149   1                      return(byte);
  150   1              }

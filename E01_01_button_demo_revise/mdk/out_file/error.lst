   31           */
   32          static float normalize_sensor(int16 value) {
   33   1      #if NORMALIZE_ENABLE
   34   1          if(value < 0) value = 0;
   35   1          if(value > NORMALIZE_MAX) value = NORMALIZE_MAX;
   36   1          return (float)value / NORMALIZE_MAX;
   37   1      #else
                   return (float)value;

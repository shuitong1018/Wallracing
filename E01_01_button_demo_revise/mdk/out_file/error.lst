   40   1      }
   41          
   42          /**
   43           * @brief   一阶低通滤波器
   44           * @param   new_value   新值
   45           * @param   last_value  上一次的值
   46           * @return  滤波后的值
   47           */
   48          static float low_pass_filter(float new_value, float last_value) {
   49   1          return FILTER_ALPHA * new_value + (1.0f - FILTER_ALPHA) * last_value;
   50   1      }

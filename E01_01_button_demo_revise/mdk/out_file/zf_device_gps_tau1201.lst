  177          static void utc_to_btc (gps_time_struct *time)
  178          {
  179   1          uint8 day_num = 0;
  180   1      
  181   1          time->hour = time->hour + 8;
  182   1          if(23 < time->hour)
  183   1          {
  184   2              time->hour -= 24;
  185   2              time->day += 1;
  186   2      
  187   2              if(2 == time->month)
  188   2              {
  189   3                  day_num = 28;
  190   3                  if((0 == time->year % 4 && 0 != time->year % 100) || 0 == time->year % 400) // ХаЖЯЪЧЗёЮЊШђФъ
  191   3                  {
  192   4                      day_num ++;                                                     // ШђдТ 2дТЮЊ29Ьь
  193   4                  }
  194   3              }
  195   2              else
  196   2              {
  197   3                  day_num = 31;                                                       // 1 3 5 7 8 10 12етаЉдТЗ
             -нЮЊ31Ьь
  198   3                  if(4  == time->month || 6  == time->month || 9  == time->month || 11 == time->month )
  199   3                  {
  200   4                      day_num = 30;
  201   4                  }
  202   3              }
  203   2      
  204   2              if(time->day > day_num)
  205   2              {
  206   3                  time->day = 1;
  207   3                  time->month ++;
  208   3                  if(12 < time->month)
  209   3                  {
  210   4                      time->month -= 12;
  211   4                      time->year ++;
  212   4                  }
  213   3              }
  214   2          }
  215   1      }

             -000dps ЛёШЁЕНЕФЭгТнвЧЪ§ОнГ§вд 28.6ЃЌ    ПЩвдзЊЛЏЮЊДјЮяРэЕЅЮЛЕФЪ§ОнЃЌЕЅЮЛЮЊЃКЁу/s
  389   2              case 0x5C: gyro_data = (float)gyro_value / 14.3f;   break;              //  0x5C ЭгТнвЧСПГЬЮЊ:ЁР2
             -000dps ЛёШЁЕНЕФЭгТнвЧЪ§ОнГ§вд 14.3ЃЌ    ПЩвдзЊЛЏЮЊДјЮяРэЕЅЮЛЕФЪ§ОнЃЌЕЅЮЛЮЊЃКЁу/s
  390   2              case 0x51: gyro_data = (float)gyro_value / 7.1f;    break;              //  0x51 ЭгТнвЧСПГЬЮЊ:ЁР4

  365   2              case 0x38: acc_data = (float)acc_value / 8197;  break;                  // 0x38 МгЫйЖШСПГЬЮЊ:ЁР4G
             -      ЛёШЁЕНЕФМгЫйЖШМЦЪ§Он Г§вд 8197 ЃЌ ПЩвдзЊЛЏЮЊДјЮяРэЕЅЮЛЕФЪ§ОнЃЌЕЅЮЛЃКg(m/s^2)
  366   2              case 0x3C: acc_data = (float)acc_value / 4098;  break;                  // 0x3C МгЫйЖШСПГЬЮЊ:ЁР8G
             -      ЛёШЁЕНЕФМгЫйЖШМЦЪ§Он Г§вд 4098 ЃЌ ПЩвдзЊЛЏЮЊДјЮяРэЕЅЮЛЕФЪ§ОнЃЌЕЅЮЛЃКg(m/s^2)
  367   2              case 0x34: acc_data = (float)acc_value / 2049;  break;                  // 0x34 МгЫйЖШСПГЬЮЊ:ЁР16
             -G     ЛёШЁЕНЕФМгЫйЖШМЦЪ§Он Г§вд 2049 ЃЌ ПЩвдзЊЛЏЮЊДјЮяРэЕЅЮЛЕФЪ§ОнЃЌЕЅЮЛЃКg(m/s^2)
